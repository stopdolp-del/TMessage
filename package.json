{
  "name": "tmessing",
  "productName": "TMessing",
  "version": "1.0.0",
  "description": "TMessing — desktop messaging (Electron + Node + WebSocket + SQLite)",
  "main": "app/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "node server/index.js",
    "dev": "electron .",
    "electron": "electron .",
    "build:win": "electron-builder --win",
    "postinstall": "node -e \"require('fs').mkdirSync('database',{recursive:true});require('fs').mkdirSync('uploads',{recursive:true});\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "sql.js": "^1.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.tmessing.app",
    "productName": "TMessing",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asarUnpack": [
      "**/node_modules/bcrypt/**/*",
      "**/node_modules/sql.js/**/*"
    ]
  }
}
